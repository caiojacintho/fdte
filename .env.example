# Read by docker-compose.yml (Compose loads `.env` from the same directory
# as the compose file, i.e. repo root) to configure the `postgres` service.
# Copy this file to `.env` (gitignored) to override; docker-compose.yml
# already falls back to these same dev-friendly defaults if no `.env` is
# present, so `docker compose up` works out-of-the-box without one.
POSTGRES_USER=planehab
POSTGRES_PASSWORD=planehab
